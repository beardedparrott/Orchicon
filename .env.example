# Orchicon local-development environment.
#
# Copy to .env and adjust. Values mirror deploy/compose/docker-compose.yml.
# The control plane reads these via internal/config (internal/config/config.go).

# Control plane listen addresses.
ORCHICON_HTTP_ADDR=:8080
ORCHICON_GRPC_ADDR=:9090

# Postgres (source of truth, docs/09).
ORCHICON_POSTGRES_DSN=postgres://orchicon:orchicon@localhost:5432/orchicon?sslmode=disable

# NATS JetStream (event bus, docs/08 §2).
ORCHICON_NATS_URL=nats://localhost:4222

# OTel collector OTLP endpoint (telemetry plane, docs/08 §5).
ORCHICON_OTEL_ENDPOINT=localhost:4317

# SigNoz query-service root (UI + API). The TelemetryService proxies
# tenant-scoped queries here (docs/08 §5, docs/10 §11). The frontend
# embeds the SigNoz UI same-origin under /signoz. Dev default matches
# deploy/compose (SigNoz UI on host :3301).
ORCHICON_SIGNOZ_URL=http://localhost:3301

# SigNoz root user password (impersonation mode, local dev only).
# Must meet: ≥12 chars, uppercase, lowercase, number, symbol.
SIGNOZ_USER_ROOT_PASSWORD=Orchicon-Dev-42!

# Local filesystem BlobStore (docs/01 §2).
ORCHICON_BLOB_DIR=./data/blobs

# Apply Atlas migrations on boot (docs/09 §8).
ORCHICON_MIGRATE_ON_BOOT=true

# --- Phase 9: Auth + deployment mode (docs/07 §6) ------------------------
# Deployment mode: "local" (fully-local dev) or "production". Production
# requires a real OIDC issuer + signing key (validated on boot).
ORCHICON_MODE=local

# OIDC issuer URL, or "local" for the built-in dev IdP that mints
# short-lived HS256 access tokens + refresh tokens with no external
# identity provider (AGENTS.md verification: full auth flow verifiable
# locally). Production sets the real issuer URL.
ORCHICON_OIDC_ISSUER=local
ORCHICON_OIDC_CLIENT_ID=orchicon
# ORCHICON_OIDC_CLIENT_SECRET=        # confidential-client secret (prod)
ORCHICON_OIDC_REDIRECT_URL=http://localhost:5173/auth/callback

# HMAC signing key for Orchicon-issued access + refresh tokens. In
# local mode the dev default is acceptable; production MUST set a
# strong random secret (config.Validate enforces this).
ORCHICON_AUTH_SIGNING_KEY=orchicon-dev-signing-key-change-in-production

# Allow the synthetic /auth/dev-login endpoint (local mode only).
ORCHICON_DEV_LOGIN=true

# --- BlobStore backend (docs/01 §2) ---------------------------------------
# "local" = production-viable filesystem store; "s3" = S3-compatible.
ORCHICON_BLOB_STORE=local
# ORCHICON_S3_BUCKET=                  # required when BLOB_STORE=s3
# ORCHICON_S3_REGION=us-east-1
# ORCHICON_S3_ENDPOINT=               # empty for AWS; set for MinIO/etc.
