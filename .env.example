# Orchicon local-development environment.
#
# Copy to .env and adjust. Values mirror deploy/compose/docker-compose.yml.
# The control plane reads these via internal/config (internal/config/config.go).

# Control plane listen addresses.
ORCHICON_HTTP_ADDR=:8080
ORCHICON_GRPC_ADDR=:9090

# Postgres (source of truth, docs/09).
ORCHICON_POSTGRES_DSN=postgres://orchicon:orchicon@localhost:5432/orchicon?sslmode=disable

# NATS JetStream (event bus, docs/08 §2).
ORCHICON_NATS_URL=nats://localhost:4222

# OTel collector OTLP endpoint (telemetry plane, docs/08 §5).
ORCHICON_OTEL_ENDPOINT=localhost:4317

# Local filesystem BlobStore (docs/01 §2).
ORCHICON_BLOB_DIR=./data/blobs

# Apply Atlas migrations on boot (docs/09 §8).
ORCHICON_MIGRATE_ON_BOOT=true
